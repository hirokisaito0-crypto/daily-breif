{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/brief-output.schema.json",
  "title": "DailyBriefLLMOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["brief_date", "topics"],
  "properties": {
    "brief_date": {
      "type": "string",
      "description": "ISO date YYYY-MM-DD for the brief (Europe/London calendar day)",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "topics": {
      "type": "array",
      "minItems": 0,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/topic" }
    }
  },
  "$defs": {
    "topic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "priority",
        "title",
        "summary",
        "facts_bullets",
        "terms_explained",
        "source_name",
        "source_url",
        "published_date",
        "background",
        "priority_reason",
        "client_share",
        "share_record",
        "internal_memo"
      ],
      "properties": {
        "priority": {
          "type": "string",
          "enum": ["immediate", "review", "reference"],
          "description": "immediate=即共有, review=要確認, reference=参考"
        },
        "title": { "type": "string", "minLength": 1 },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "冒頭リード。誰が何をしたかが30秒でわかる2〜4文（です・ます調）。評論より事実の骨子。"
        },
        "facts_bullets": {
          "type": "array",
          "description": "候補RSSに基づく具体的事実を3〜6行。誰・いつ・何を・数値・期限など。推測は明示。",
          "minItems": 3,
          "maxItems": 6,
          "items": { "type": "string", "minLength": 8 }
        },
        "terms_explained": {
          "type": "array",
          "description": "本文で使った略語・制度・当局を新卒向けに一言解説。2〜5件。",
          "minItems": 2,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["term", "definition"],
            "properties": {
              "term": {
                "type": "string",
                "minLength": 1,
                "description": "用語（略称も可）"
              },
              "definition": {
                "type": "string",
                "minLength": 8,
                "description": "新卒向けの短い説明（です・ます調）"
              }
            }
          }
        },
        "source_name": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "minLength": 4 },
        "published_date": {
          "type": "string",
          "description": "Display as YYYY-MM-DD",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "background": { "type": "string" },
        "priority_reason": { "type": "string" },
        "client_share": {
          "type": "string",
          "enum": ["recommended", "judgment", "not_recommended"],
          "description": "クライアント共有: 推奨 / 要判断 / 非推奨"
        },
        "share_record": {
          "type": "string",
          "enum": ["pending", "done_shared", "done_skipped"],
          "description": "新規生成時は通常 pending"
        },
        "internal_memo": {
          "type": "string",
          "description": "空文字なら社内メモブロックを非表示"
        }
      }
    }
  }
}
